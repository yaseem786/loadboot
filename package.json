{
  "name": "loadboot-phase2a-tests",
  "version": "0.0.0",
  "private": true,
  "description": "Local, pinned test dependencies for the Phase 2A test harness (service-worker functional test).",
  "scripts": {
    "test:pwa": "node tests/sw_functional_test.mjs",
    "test:all": "bash tests/run_all.sh",
    "test:personas": "playwright test tests/security/persona_matrix.spec.js --reporter=list,json,html",
    "test:pod": "playwright test tests/security/pod_workflow.spec.js --reporter=list,json,html",
    "pw:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "1.56.0",
    "playwright": "1.56.0"
  }
}
